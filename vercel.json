{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "data.js", "use": "@vercel/static" },
    { "src": "locationService.js", "use": "@vercel/static" },
    { "src": "provinces_vn.json", "use": "@vercel/static" },
    { "src": "scam_blacklist.json", "use": "@vercel/static" },
    { "src": "landlord_rooms.json", "use": "@vercel/static" },
    { "src": "roommates.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
